# Rust
# Cargo.lock is intentionally committed: sizer-cli/sizer-api are binaries,
# and this workspace has no published library crates, so we want
# reproducible builds rather than floating dependency versions.
/target/
**/*.rs.bk
*.pdb

# Tauri: schemas regenerated by tauri-build on every build
crates/sizer-desktop/gen/

# wasm-bindgen output: regenerated by `wasm-bindgen --target web ...`,
# see crates/sizer-wasm's README note / CONTRIBUTING.md for the command
crates/sizer-wasm/pkg/

# misc
.DS_Store
*.pem

# env files -- .env.example is a template with no secrets and is meant
# to be committed (see crates/sizer-cloud/README.md's local dev setup)
.env*
!.env.example
